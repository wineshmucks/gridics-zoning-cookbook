          "response": {
            "body": "{\"status\":\"OK\",\"searchType\":4,\"dataRows\":1,\"data\":[{\"Id\":7612434,\"GroupId\":\"2fcee4fbd4bb10b04\",\"Address\":\"3675 S MIAMI AVE\",\"State\":\"FL\",\"City\":\"Miami\",\"ZipCode\":\"33133\",\"FolioNumber\":\"0141140050061\",\"LotType\":3,\"CalculationStatus\":1,\"updatedAt\":\"2026-03-26T10:02:50.058Z\",\"Buildings\":[{\"Overlays\":[{\"Id\":19870,\"Name\":\"City Future Land Use Major Institutional, Public Facilities, Transportation and Utilities\",\"Description\":null,\"CalibrationType\":4,\"GridicsId\":\"fl-city-land_use-majorinstpublicfacilitiestranspand-1245000-1\",\"Attributes\":[]},{\"Id\":40644,\"Name\":\"LEED Certified\",\"Description\":\"All new Buildings of more than 50,000 square feet of Habitable Rooms or Habitable Space in the T5, T6, CI and CS zones shall be at a minimum certified as Silver by the United States Green Building Council (USGBC) Leadership in Energy and Environmental Design (LEED) standards or equivalent standards adopted or approved by the City.\",\"CalibrationType\":4,\"GridicsId\":null,\"Attributes\":[{\"Id\":7038,\"AttributeType\":0,\"AttributeValue\":\"https://codehub.gridics.com/us/fl/miami#/cd9d9570-550f-47be-b530-33c1d29c4db3/fb1b3549-ca77-4776-a4de-af41dda5d05a/2c78f85c-2438-4b7a-9530-d91c189d60f7\",\"Description\":\"Section 3.13.1 (b)\",\"IsEnabled\":null}]},{\"Id\":79686,\"Name\":\"Live Local (SB 102) - Applicable\",\"Description\":\"<p><span style=\\\"color: rgb(51, 51, 51);\\\">The page provides a proposed set of rules and processes for implementing SB 102 (2023), inclusive of the recent legislative changes made by SB 328 (2024), known as the \u201cLive Local Act\u201d (\u201cAct\u201d).&nbsp;</span><strong style=\\\"color: rgb(51, 51, 51);\\\">Please check back often as these guidelines will be refined as we work through the initial round of Live Local Act projects.&nbsp;</strong><span style=\\\"color: rgb(51, 51, 51);\\\">Where words are capitalized, it generally indicates a defined term in Miami 21.</span></p><ul><li>The highest density allowed in the jurisdiction, which is 1000 dwelling units per acre;</li><li>The height permitted within 1 mile \u201cfor a commercial or residential development\u201d (unless restricted due to adjacency to a T3 Transect Zone);</li><li>If located in a zone without multifamily use, such use is permitted by right, unless T3; and</li><li>An FLR of 36.</li></ul>\",\"CalibrationType\":4,\"GridicsId\":null,\"Attributes\":[{\"Id\":25346,\"AttributeType\":0,\"AttributeValue\":\"https://www.miami.gov/My-Government/Departments/Zoning/SB-102-Live-Local-Act\",\"Description\":\"Live Local Miami Definition\",\"IsEnabled\":null}]},{\"Id\":40019,\"Name\":\"Off-street bicycle parking\",\"Description\":\"<p>Shall be provided for all T4, T5, T6, CS, CI, CI-HD, and D zones, as shown in Article 4, Table 4, Miami21.</p>\",\"CalibrationType\":4,\"GridicsId\":null,\"Attributes\":[]}],\"Uses\":[{\"CalibrationUsesLabelId\":5,\"AllowedUsesId\":1,\"TypeId\":1,\"TypeName\":\"Residential\",\"TypeNameLabel\":null,\"AllowedUsesLabel\":\"R\",\"AllowedUsesName\":\"by Right\",\"AllowedUsesDescription\":\"Allowed by Right.  \\nA Use or Structure allowed pursuant to zoning review and approval of a Building Permit or issuance of a Certificate of Use under Article 7, Section 7.1.2.1., titled \u201cPermitted Uses,\u201d and without approval by Waiver, Warrant, Exception, Variance, or other required City Commission, Historic and Environmental Preservation Board, or Planning, Zoning, and Appeals Board approval.\",\"UseConditionId\":1,\"CalibrationUsesLabel\":\"Multi Family Housing\",\"CalibrationUsesLabelClassId\":1,\"CalibrationUsesLabelClassName\":\"Primary\",\"CalibrationUseLabelAttributes\":[{\"Id\":418,\"AttributeType\":1,\"AttributeValue\":\"<p>A Building or portion thereof, containing three or more Dwelling Units where each unit has direct access to the outside or to a common hall. A multifamily Structure where Dwelling Units are available for lease or rent for less than one month shall be considered Lodging.</p>\",\"Description\":null,\"IsEnabled\":null}],\"UseAllowanceAttributes\":[],\"UseLimitAttributes\":[],\"ParkingRequiredAttributes\":[]},{\"CalibrationUsesLabelId\":6,\"AllowedUsesId\":3,\"TypeId\":1,\"TypeName\":\"Residential\",\"TypeNameLabel\":null,\"AllowedUsesLabel\":\"E\",\"AllowedUsesName\":\"by Exception\",\"AllowedUsesDescription\":\"Allowed By Exception: Public Hearing - granted by PZAB (Planning, Zoning & Appeals Board)\",\"UseConditionId\":3,\"CalibrationUsesLabel\":\"Dormitory\",\"CalibrationUsesLabelClassId\":1,\"CalibrationUsesLabelClassName\":\"Primary\",\"CalibrationUseLabelAttributes\":[{\"Id\":419,\"AttributeType\":1,\"AttributeValue\":\"<p>A Building used principally for sleeping accommodations for students or staff related to an educational institution or place of employment.</p>\",\"Description\":null,\"IsEnabled\":null}],\"UseAllowanceAttributes\":[],\"UseLimitAttributes\":[],\"ParkingRequiredAttributes\":[]},{\"CalibrationUsesLabelId\":13,\"AllowedUsesId\":3,\"TypeId\":3,\"TypeName\":\"Office\",\"TypeNameLabel\":null,\"AllowedUsesLabel\":\"E\",\"AllowedUsesName\":\"by Exception\",\"AllowedUsesDescription\":\"Allowed By Exception: Public Hearing - granted by PZAB (Planning, Zoning & Appeals Board)\",\"UseConditionId\":3,\"CalibrationUsesLabel\":\"Office\",\"CalibrationUsesLabelClassId\":1,\"CalibrationUsesLabelClassName\":\"Primary\",\"CalibrationUseLabelAttributes\":[{\"Id\":426,\"AttributeType\":1,\"AttributeValue\":\"<p>A Building or portion thereof used for conducting a business, profession, service, or government. Such facilities may include, but are not limited to, offices of attorneys, engineers, architects, physicians, dentists, accountants, financial institutions, real estate companies, insurance companies, financial planners, or corporate offices, and exclude manufacturing activities.</p>\",\"Description\":null,\"IsEnabled\":null}],\"UseAllowanceAttributes\":[],\"UseLimitAttributes\":[],\"ParkingRequiredAttributes\":[]},{\"CalibrationUsesLabelId\":17,\"AllowedUsesId\":3,\"TypeId\":4,\"TypeName\":\"Commercial\",\"TypeNameLabel\":null,\"AllowedUsesLabel\":\"E\",\"AllowedUsesName\":\"by Exception\",\"AllowedUsesDescription\":\"Allowed By Exception: Public Hearing - granted by PZAB (Planning, Zoning & Appeals Board)\",\"UseConditionId\":3,\"CalibrationUsesLabel\":\"Food Service Establishment\",\"CalibrationUsesLabelClassId\":1,\"CalibrationUsesLabelClassName\":\"Primary\",\"CalibrationUseLabelAttributes\":[{\"Id\":430,\"AttributeType\":1,\"AttributeValue\":\"<p>A place of business dedicated to the preparation and sale of food and beverage for immediate consumption on or off site.</p>\",\"Description\":null,\"IsEnabled\":null}],\"UseAllowanceAttributes\":[],\"UseLimitAttributes\":[],\"ParkingRequiredAttributes\":[]},{\"CalibrationUsesLabelId\":19,\"AllowedUsesId\":3,\"TypeId\":4,\"TypeName\":\"Commercial\",\"TypeNameLabel\":null,\"AllowedUsesLabel\":\"E\",\"AllowedUsesName\":\"by Exception\",\"AllowedUsesDescription\":\"Allowed By Exception: Public Hearing - granted by PZAB (Planning, Zoning & Appeals Board)\",\"UseConditionId\":3,\"CalibrationUsesLabel\":\"General Commercial\",\"CalibrationUsesLabelClassId\":1,\"CalibrationUsesLabelClassName\":\"Primary\",\"CalibrationUseLabelAttributes\":[{\"Id\":432,\"AttributeType\":1,\"AttributeValue\":\"<p>A place of business providing the sale and display of goods or sale of services directly to the consumer, with goods available for immediate purchase and removal from the premises by the purchaser. General commercial goods include, but are not limited to, clothing, food, furniture, pharmaceuticals, books, art objects and the like. General commercial services include, but are not limited to, barber shops; beauty salons; travel agencies; fortune tellers; retail dry cleaning; express delivery service; health spas and fitness studios; photo studios; Funeral Homes; Animal Clinics; repair service establishments, Employment Office; Public Storage Facilities, and the like. General Commercial services exclude: Auto-Related or Marine-Related Establishments; Commercial Storage Facilities, Pawn Shops, and the like.</p>\",\"Description\":null,\"IsEnabled\":null}],\"UseAllowanceAttributes\":[],\"UseLimitAttributes\":[],\"ParkingRequiredAttributes\":[]},{\"CalibrationUsesLabelId\":21,\"AllowedUsesId\":3,\"TypeId\":4,\"TypeName\":\"Commercial\",\"TypeNameLabel\":null,\"AllowedUsesLabel\":\"E\",\"AllowedUsesName\":\"by Exception\",\"AllowedUsesDescription\":\"Allowed By Exception: Public Hearing - granted by PZAB (Planning, Zoning & Appeals Board)\",\"UseConditionId\":3,\"CalibrationUsesLabel\":\"Open Air Retail\",\"CalibrationUsesLabelClassId\":1,\"CalibrationUsesLabelClassName\":\"Primary\",\"CalibrationUseLabelAttributes\":[{\"Id\":434,\"AttributeType\":1,\"AttributeValue\":\"<p>A retail sales establishment operated substantially in the open air including, but not limited to: farmers market, Flea Markets, and the like. Uses not included are: car sales, equipment sales, boats sales, and home and garden supplies and equipment.</p>\",\"Description\":null,\"IsEnabled\":null},{\"Id\":2786,\"AttributeType\":0,\"AttributeValue\":\"https://codehub.gridics.com/us/fl/miami#/413cd52e-98d0-40c0-b946-a16d4d84c0c6\",\"Description\":\"See Article 6\",\"IsEnabled\":null}],\"UseAllowanceAttributes\":[],\"UseLimitAttributes\":[],\"ParkingRequiredAttributes\":[]},{\"CalibrationUsesLabelId\":22,\"AllowedUsesId\":3,\"TypeId\":4,\"TypeName\":\"Commercial\",\"TypeNameLabel\":null,\"AllowedUsesLabel\":\"E\",\"AllowedUsesName\":\"by Exception\",\"AllowedUsesDescription\":\"Allowed By Exception: Public Hearing - granted by PZAB (Planning, Zoning & Appeals Board)\",\"UseConditionId\":3,\"CalibrationUsesLabel\":\"Place of Assembly\",\"CalibrationUsesLabelClassId\":1,\"CalibrationUsesLabelClassName\":\"Primary\",\"CalibrationUseLabelAttributes\":[{\"Id\":435,\"AttributeType\":1,\"AttributeValue\":\"<p>A commercial facility for public assembly including, but not limited to: arenas, auditoriums, conference facilities, convention centers, exhibition halls, major sports facilities, theaters and performing arts centers, and the like.</p>\",\"Description\":null,\"IsEnabled\":null}],\"UseAllowanceAttributes\":[],\"UseLimitAttributes\":[],\"ParkingRequiredAttributes\":[]},{\"CalibrationUsesLabelId\":23,\"AllowedUsesId\":3,\"TypeId\":4,\"TypeName\":\"Commercial\",\"TypeNameLabel\":null,\"AllowedUsesLabel\":\"E\",\"AllowedUsesName\":\"by Exception\",\"AllowedUsesDescription\":\"Allowed By Exception: Public Hearing - granted by PZAB (Planning, Zoning & Appeals Board)\",\"UseConditionId\":3,\"CalibrationUsesLabel\":\"Recreation Establishment\",\"CalibrationUsesLabelClassId\":1,\"CalibrationUsesLabelClassName\":\"Primary\",\"CalibrationUseLabelAttributes\":[{\"Id\":436,\"AttributeType\":1,\"AttributeValue\":\"<p>A place of business providing group leisure activities, often requiring equipment and open to the public with or without entry or activity fees. This may include, but is not limited to: game courts, skating rinks, bowling alleys, commercial golf facility, gyms or sports rooms.</p>\",\"Description\":null,\"IsEnabled\":null}],\"UseAllowanceAttributes\":[],\"UseLimitAttributes\":[],\"ParkingRequiredAttributes\":[]},{\"CalibrationUsesLabelId\":24,\"AllowedUsesId\":3,\"TypeId\":5,\"TypeName\":\"Civic\",\"TypeNameLabel\":null,\"AllowedUsesLabel\":\"E\",\"AllowedUsesName\":\"by Exception\",\"AllowedUsesDescription\":\"Allowed By Exception: Public Hearing - granted by PZAB (Planning, Zoning & Appeals Board)\",\"UseConditionId\":3,\"CalibrationUsesLabel\":\"Community Facility\",\"CalibrationUsesLabelClassId\":1,\"CalibrationUsesLabelClassName\":\"Primary\",\"CalibrationUseLabelAttributes\":[{\"Id\":437,\"AttributeType\":1,\"AttributeValue\":\"<p>A non-commercial facility established primarily for the benefit and service of the general public of the community in which it is located. Such facilities include, but are not limited to: community centers; City of Miami NET offices; and cultural facilities, such as libraries and museums.</p>\",\"Description\":null,\"IsEnabled\":null}],\"UseAllowanceAttributes\":[],\"UseLimitAttributes\":[],\"ParkingRequiredAttributes\":[]},{\"CalibrationUsesLabelId\":25,\"AllowedUsesId\":3,\"TypeId\":5,\"TypeName\":\"Civic\",\"TypeNameLabel\":null,\"AllowedUsesLabel\":\"E\",\"AllowedUsesName\":\"by Exception\",\"AllowedUsesDescription\":\"Allowed By Exception: Public Hearing - granted by PZAB (Planning, Zoning & Appeals Board)\",\"UseConditionId\":3,\"CalibrationUsesLabel\":\"Recreational Facility\",\"CalibrationUsesLabelClassId\":1,\"CalibrationUsesLabelClassName\":\"Primary\",\"CalibrationUseLabelAttributes\":[{\"Id\":438,\"AttributeType\":1,\"AttributeValue\":\"<p>A non-commercial facility, primarily an open space, serving the recreation needs of the general public. This may include but is not limited to: golf courses, parks, camping facilities, playfields and playgrounds.</p>\",\"Description\":null,\"IsEnabled\":null}],\"UseAllowanceAttributes\":[],\"UseLimitAttributes\":[],\"ParkingRequiredAttributes\":[]},{\"CalibrationUsesLabelId\":26,\"AllowedUsesId\":3,\"TypeId\":5,\"TypeName\":\"Civic\",\"TypeNameLabel\":null,\"AllowedUsesLabel\":\"E\",\"AllowedUsesName\":\"by Exception\",\"AllowedUsesDescription\":\"Allowed By Exception: Public Hearing - granted by PZAB (Planning, Zoning & Appeals Board)\",\"UseConditionId\":3,\"CalibrationUsesLabel\":\"Religious Facility\",\"CalibrationUsesLabelClassId\":1,\"CalibrationUsesLabelClassName\":\"Primary\",\"CalibrationUseLabelAttributes\":[{\"Id\":439,\"AttributeType\":1,\"AttributeValue\":\"<p>A facility used for regular organized religious worship and related activities.</p>\",\"Description\":null,\"IsEnabled\":null}],\"UseAllowanceAttributes\":[],\"UseLimitAttributes\":[],\"ParkingRequiredAttributes\":[]},{\"CalibrationUsesLabelId\":27,\"AllowedUsesId\":3,\"TypeId\":6,\"T