                                "Overlays": [
                                  {
                                    "Attributes": [],
                                    "CalibrationType": 4,
                                    "Description": null,
                                    "GridicsId": "fl-city-land_use-majorinstpublicfacilitiestranspand-1245000-1",
                                    "Id": 19870,
                                    "Name": "City Future Land Use Major Institutional, Public Facilities, Transportation and Utilities"
                                  },
                                  {
                                    "Attributes": [
                                      {
                                        "AttributeType": 0,
                                        "AttributeValue": "https://codehub.gridics.com/us/fl/miami#/cd9d9570-550f-47be-b530-33c1d29c4db3/fb1b3549-ca77-4776-a4de-af41dda5d05a/2c78f85c-2438-4b7a-9530-d91c189d60f7",
                                        "Description": "Section 3.13.1 (b)",
                                        "Id": 7038,
                                        "IsEnabled": null
                                      }
                                    ],
                                    "CalibrationType": 4,
                                    "Description": "All new Buildings of more than 50,000 square feet of Habitable Rooms or Habitable Space in the T5, T6, CI and CS zones shall be at a minimum certified as Silver by the United States Green Building Council (USGBC) Leadership in Energy and Environmental Design (LEED) standards or equivalent standards adopted or approved by the City.",
                                    "GridicsId": null,
                                    "Id": 40644,
                                    "Name": "LEED Certified"
                                  },
                                  {
                                    "Attributes": [
                                      {
                                        "AttributeType": 0,
                                        "AttributeValue": "https://www.miami.gov/My-Government/Departments/Zoning/SB-102-Live-Local-Act",
                                        "Description": "Live Local Miami Definition",
                                        "Id": 25346,
                                        "IsEnabled": null
                                      }
                                    ],
                                    "CalibrationType": 4,
                                    "Description": "<p><span style=\"color: rgb(51, 51, 51);\">The page provides a proposed set of rules and processes for implementing SB 102 (2023), inclusive of the recent legislative changes made by SB 328 (2024), known as the “Live Local Act” (“Act”).&nbsp;</span><strong style=\"color: rgb(51, 51, 51);\">Please check back often as these guidelines will be refined as we work through the initial round of Live Local Act projects.&nbsp;</strong><span style=\"color: rgb(51, 51, 51);\">Where words are capitalized, it generally indicates a defined term in Miami 21.</span></p><ul><li>The highest density allowed in the jurisdiction, which is 1000 dwelling units per acre;</li><li>The height permitted within 1 mile “for a commercial or residential development” (unless restricted due to adjacency to a T3 Transect Zone);</li><li>If located in a zone without multifamily use, such use is permitted by right, unless T3; and</li><li>An FLR of 36.</li></ul>",
                                    "GridicsId": null,
                                    "Id": 79686,
                                    "Name": "Live Local (SB 102) - Applicable"
                                  },
                                  {
                                    "Attributes": [],
                                    "CalibrationType": 4,
                                    "Description": "<p>Shall be provided for all T4, T5, T6, CS, CI, CI-HD, and D zones, as shown in Article 4, Table 4, Miami21.</p>",
                                    "GridicsId": null,
                                    "Id": 40019,
                                    "Name": "Off-street bicycle parking"
                                  }
                                ],
                                "Uses": [
                                  {
                                    "AllowedUsesDescription": "Allowed by Right.  \nA Use or Structure allowed pursuant to zoning review and approval of a Building Permit or issuance of a Certificate of Use under Article 7, Section 7.1.2.1., titled “Permitted Uses,” and without approval by Waiver, Warrant, Exception, Variance, or other required City Commission, Historic and Environmental Preservation Board, or Planning, Zoning, and Appeals Board approval.",
                                    "AllowedUsesId": 1,
                                    "AllowedUsesLabel": "R",
                                    "AllowedUsesName": "by Right",
                                    "CalibrationUseLabelAttributes": [
                                      {
                                        "AttributeType": 1,
                                        "AttributeValue": "<p>A Building or portion thereof, containing three or more Dwelling Units where each unit has direct access to the outside or to a common hall. A multifamily Structure where Dwelling Units are available for lease or rent for less than one month shall be considered Lodging.</p>",
                                        "Description": null,
                                        "Id": 418,
                                        "IsEnabled": null
                                      }
                                    ],
                                    "CalibrationUsesLabel": "Multi Family Housing",
                                    "CalibrationUsesLabelClassId": 1,
