aws_region          = "us-east-1"
environment         = "prod"
tag_env             = "prod"
tag_name            = "gridics-zoning-suite"
app_allowed_origins = "https://uzone.example.com"
use_existing_vpc    = false
use_existing_alb    = false
existing_vpc_id     = ""
existing_public_subnet_ids  = []
existing_private_subnet_ids = []
existing_alb_arn                = ""
existing_alb_http_listener_arn  = ""
existing_alb_https_listener_arn = ""
existing_alb_host_header        = ""
existing_alb_frontend_rule_priority = 110
existing_alb_api_rule_priority      = 100
assets_bucket_name  = "gridics-uzones"
public_base_url     = "https://uzone.example.com"

db_name     = "uzone"
db_username = "uzone"
db_password = "replace-me"
db_engine_version = "16.13"

backend_image_tag  = "latest"
frontend_image_tag = "latest"

backend_environment = {
  UZONE_AUTH_PROVIDER            = "clerk"
  UZONE_PAYMENT_PROVIDERS        = "manual"
  UZONE_DEFAULT_PAYMENT_PROVIDER = "manual"
  UZONE_EMAIL_PROVIDER           = "console"
  UZONE_EMAIL_FROM               = "noreply@example.com"
  CLERK_JWKS_URL                = "https://your-clerk-instance.clerk.accounts.dev/.well-known/jwks.json"
  CLERK_AUTHORIZED_PARTIES      = "https://uzone.example.com"
  UZONE_ASSETS_PREFIX            = "jurisdictions"
}

frontend_environment = {
  GRIDICS_CLERK_ORGANIZATION_SLUG   = "gridics"
  NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY = "pk_live_or_pk_test_replace_me"
  NEXT_PUBLIC_CLERK_JWKS_URL        = "https://your-clerk-instance.clerk.accounts.dev/.well-known/jwks.json"
  CLERK_SECRET_KEY                  = "sk_live_or_sk_test_replace_me"
}

backend_secret_arns  = {}
frontend_secret_arns = {}
