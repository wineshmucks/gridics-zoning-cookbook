\"IsEnabled\":null},{\"Id\":2784,\"AttributeType\":0,\"AttributeValue\":\"https://codehub.gridics.com/us/fl/miami#/413cd52e-98d0-40c0-b946-a16d4d84c0c6\",\"Description\":\"See Article 6\",\"IsEnabled\":null}],\"UseAllowanceAttributes\":[],\"UseLimitAttributes\":[],\"ParkingRequiredAttributes\":[]},{\"CalibrationUsesLabelId\":29,\"AllowedUsesId\":3,\"TypeId\":6,\"TypeName\":\"Civic Support\",\"TypeNameLabel\":null,\"AllowedUsesLabel\":\"E\",\"AllowedUsesName\":\"by Exception\",\"AllowedUsesDescription\":\"Allowed By Exception: Public Hearing - granted by PZAB (Planning, Zoning & Appeals Board)\",\"UseConditionId\":3,\"CalibrationUsesLabel\":\"Major Facility\",\"CalibrationUsesLabelClassId\":1,\"CalibrationUsesLabelClassName\":\"Primary\",\"CalibrationUseLabelAttributes\":[{\"Id\":442,\"AttributeType\":1,\"AttributeValue\":\"<p>A large facility of an institutional nature including but not limited to Hospitals, public health and social service facilities, research facilities, shelters, judicial Buildings, Jails, Detention Facilities, work camps, cemeteries, mausoleums, Ambulance Services, Pharmaceutical Laboratories, or the like.</p>\",\"Description\":null,\"IsEnabled\":null}],\"UseAllowanceAttributes\":[],\"UseLimitAttributes\":[],\"ParkingRequiredAttributes\":[]},{\"CalibrationUsesLabelId\":30,\"AllowedUsesId\":3,\"TypeId\":6,\"TypeName\":\"Civic Support\",\"TypeNameLabel\":null,\"AllowedUsesLabel\":\"E\",\"AllowedUsesName\":\"by Exception\",\"AllowedUsesDescription\":\"Allowed By Exception: Public Hearing - granted by PZAB (Planning, Zoning & Appeals Board)\",\"UseConditionId\":3,\"CalibrationUsesLabel\":\"Marina\",\"CalibrationUsesLabelClassId\":1,\"CalibrationUsesLabelClassName\":\"Primary\",\"CalibrationUseLabelAttributes\":[{\"Id\":443,\"AttributeType\":1,\"AttributeValue\":\"<p>A facility for storage, servicing, fueling, berthing, or securing of boats. The Use does not include marine-related industrial activities.</p>\",\"Description\":null,\"IsEnabled\":null}],\"UseAllowanceAttributes\":[],\"UseLimitAttributes\":[],\"ParkingRequiredAttributes\":[]},{\"CalibrationUsesLabelId\":31,\"AllowedUsesId\":3,\"TypeId\":6,\"TypeName\":\"Civic Support\",\"TypeNameLabel\":null,\"AllowedUsesLabel\":\"E\",\"AllowedUsesName\":\"by Exception\",\"AllowedUsesDescription\":\"Allowed By Exception: Public Hearing - granted by PZAB (Planning, Zoning & Appeals Board)\",\"UseConditionId\":3,\"CalibrationUsesLabel\":\"Public Parking\",\"CalibrationUsesLabelClassId\":1,\"CalibrationUsesLabelClassName\":\"Primary\",\"CalibrationUseLabelAttributes\":[{\"Id\":444,\"AttributeType\":1,\"AttributeValue\":\"<p>A parking facility available to the general public for parking motor vehicles, including parking lots or garages.</p>\",\"Description\":null,\"IsEnabled\":null}],\"UseAllowanceAttributes\":[],\"UseLimitAttributes\":[],\"ParkingRequiredAttributes\":[]},{\"CalibrationUsesLabelId\":32,\"AllowedUsesId\":3,\"TypeId\":6,\"TypeName\":\"Civic Support\",\"TypeNameLabel\":null,\"AllowedUsesLabel\":\"E\",\"AllowedUsesName\":\"by Exception\",\"AllowedUsesDescription\":\"Allowed By Exception: Public Hearing - granted by PZAB (Planning, Zoning & Appeals Board)\",\"UseConditionId\":3,\"CalibrationUsesLabel\":\"Rescue Mission\",\"CalibrationUsesLabelClassId\":1,\"CalibrationUsesLabelClassName\":\"Primary\",\"CalibrationUseLabelAttributes\":[{\"Id\":445,\"AttributeType\":1,\"AttributeValue\":\"<p>A facility providing personal assistance to individuals in need; such assistance to individuals may include temporary shelter, food services provisions, counseling, instruction, medical services, and other incidental services.</p>\",\"Description\":null,\"IsEnabled\":null}],\"UseAllowanceAttributes\":[],\"UseLimitAttributes\":[],\"ParkingRequiredAttributes\":[]},{\"CalibrationUsesLabelId\":33,\"AllowedUsesId\":3,\"TypeId\":6,\"TypeName\":\"Civic Support\",\"TypeNameLabel\":null,\"AllowedUsesLabel\":\"E\",\"AllowedUsesName\":\"by Exception\",\"AllowedUsesDescription\":\"All