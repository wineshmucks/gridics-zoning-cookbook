TypeId\":7,\"TypeName\":\"Educational\",\"TypeNameLabel\":null,\"AllowedUsesLabel\":\"E\",\"AllowedUsesName\":\"by Exception\",\"AllowedUsesDescription\":\"Allowed By Exception: Public Hearing - granted by PZAB (Planning, Zoning & Appeals Board)\",\"UseConditionId\":3,\"CalibrationUsesLabel\":\"College / University\",\"CalibrationUsesLabelClassId\":1,\"CalibrationUsesLabelClassName\":\"Primary\",\"CalibrationUseLabelAttributes\":[{\"Id\":448,\"AttributeType\":1,\"AttributeValue\":\"<p>A facility for post-secondary education that grants associate, bachelor, master or doctoral degrees, and may include research functions or professional schools.</p>\",\"Description\":null,\"IsEnabled\":null}],\"UseAllowanceAttributes\":[],\"UseLimitAttributes\":[],\"ParkingRequiredAttributes\":[]},{\"CalibrationUsesLabelId\":36,\"AllowedUsesId\":3,\"TypeId\":7,\"TypeName\":\"Educational\",\"TypeNameLabel\":null,\"AllowedUsesLabel\":\"E\",\"AllowedUsesName\":\"by Exception\",\"AllowedUsesDescription\":\"Allowed By Exception: Public Hearing - granted by PZAB (Planning, Zoning & Appeals Board)\",\"UseConditionId\":3,\"CalibrationUsesLabel\":\"Elementary School\",\"CalibrationUsesLabelClassId\":1,\"CalibrationUsesLabelClassName\":\"Primary\",\"CalibrationUseLabelAttributes\":[{\"Id\":449,\"AttributeType\":1,\"AttributeValue\":\"<p>A facility offering instruction at the elementary school level.</p>\",\"Description\":null,\"IsEnabled\":null}],\"UseAllowanceAttributes\":[],\"UseLimitAttributes\":[],\"ParkingRequiredAttributes\":[]},{\"CalibrationUsesLabelId\":37,\"AllowedUsesId\":3,\"TypeId\":7,\"TypeName\":\"Educational\",\"TypeNameLabel\":null,\"AllowedUsesLabel\":\"E\",\"AllowedUsesName\":\"by Exception\",\"AllowedUsesDescription\":\"Allowed By Exception: Public Hearing - granted by PZAB (Planning, Zoning & Appeals Board)\",\"UseConditionId\":3,\"CalibrationUsesLabel\":\"Learning Center\",\"CalibrationUsesLabelClassId\":1,\"CalibrationUsesLabelClassName\":\"Primary\",\"CalibrationUseLabelA