WORKBOOK_TEMPLATE_PATH=./Gridcs.xlsx
DEFAULT_SOURCE_KIND=municode
DEFAULT_SOURCE_URL=https://library.municode.com/tx/abilene/codes/code_of_ordinances
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5433/gridics_forge
DATABASE_ECHO=false

POSTGRES_IMAGE=pgvector/pgvector:pg16
POSTGRES_DB=gridics_forge
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5433

GROQ_API_KEY=...
GOOGLE_API_KEY=...
OPENROUTER_API_KEY=...

SMALL_MODEL_PROVIDER=openai
SMALL_MODEL_ID=openai/gpt-oss-20b

MEDIUM_MODEL_PROVIDER=openai
MEDIUM_MODEL_ID=openai/gpt-oss-20b

LARGE_MODEL_PROVIDER=openai
LARGE_MODEL_ID=openai/gpt-oss-120b

# optional task overrides
TEAM_COORDINATOR_PROVIDER=groq
TEAM_COORDINATOR_MODEL_ID=llama-3.3-70b-versatile
INTAKE_PROVIDER=openai
INTAKE_MODEL_ID=openai/gpt-oss-20b
DISTRICT_EXTRACTION_PROVIDER=openai
DISTRICT_EXTRACTION_MODEL_ID=openai/gpt-oss-20b
USE_EXTRACTION_PROVIDER=openai
USE_EXTRACTION_MODEL_ID=openai/gpt-oss-120b
DIMENSIONAL_EXTRACTION_PROVIDER=openai
DIMENSIONAL_EXTRACTION_MODEL_ID=openai/gpt-oss-20b
PARKING_EXTRACTION_PROVIDER=openai
PARKING_EXTRACTION_MODEL_ID=openai/gpt-oss-20b
OVERLAY_EXTRACTION_PROVIDER=openai
OVERLAY_EXTRACTION_MODEL_ID=openai/gpt-oss-120b
QA_REVIEW_PROVIDER=openai
QA_REVIEW_MODEL_ID=openai/gpt-oss-120b

EMBEDDING_PROVIDER=openrouter
EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free
EMBEDDING_DIMENSIONS=2048
EMBEDDING_BATCH_SIZE=32
EMBEDDING_API_KEY=...
EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
